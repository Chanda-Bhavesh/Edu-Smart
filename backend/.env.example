# ============================================================
#  SCMS Backend — Environment Variables
#  Copy this file to .env and fill in your values.
#  Push THIS file (.env.example) to GitHub, NOT .env
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME=SCMS
# development | production
APP_ENV=production
# Any long random string (run: python -c "import secrets; print(secrets.token_hex(32))")
APP_SECRET_KEY=CHANGE_ME_generate_a_random_string_here
DEBUG=false

# ── Database ─────────────────────────────────────────────────
# SQLite (simple, works for small deployments):
DATABASE_URL=sqlite+aiosqlite:///./scms.db
# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/scms_db

# ── Redis (optional — app works without it) ──────────────────
# If you have Redis, set this. Otherwise leave blank and token
# blacklisting is skipped (safe for most deployments).
REDIS_URL=redis://localhost:6379/0

# ── JWT ──────────────────────────────────────────────────────
# Any long random string (different from APP_SECRET_KEY)
JWT_SECRET_KEY=CHANGE_ME_another_random_string_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Email / SMTP ─────────────────────────────────────────────
# Leave blank to disable email features (no errors, just no emails sent)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail@gmail.com
# For Gmail: use an App Password (not your real password)
# Guide: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your_gmail_app_password
EMAILS_FROM_EMAIL=noreply@yourdomain.com
EMAILS_FROM_NAME=SCMS Platform

# ── Frontend ─────────────────────────────────────────────────
# The URL where your frontend is deployed (used in email links)
FRONTEND_URL=https://your-frontend.onrender.com
# Comma-separated list — add your frontend URL here
ALLOWED_ORIGINS=https://your-frontend.onrender.com

# ── File Storage ─────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── AI / Claude (optional) ────────────────────────────────────
# Get your key at: https://console.anthropic.com
# Leave blank to disable the AI chatbot feature
ANTHROPIC_API_KEY=
AI_CHAT_MODEL=claude-haiku-4-5-20251001
AI_CHAT_MAX_TOKENS=1024
AI_CHAT_HISTORY_LIMIT=10
